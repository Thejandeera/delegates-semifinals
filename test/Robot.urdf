<?xml version="1.0"?>
<robot name="robot">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0415" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.08"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.0415" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.08"/>
      </geometry>
    </collision>
  </link>
  <joint name="motor_2" type="continuous">
    <parent link="base_link"/>
    <child link="solid_1"/>
    <axis xyz="0.000796 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="-0.045 0 0.025" rpy="0 1.57 0"/>
  </joint>
  <link name="solid_1">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.01"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.01"/>
      </geometry>
    </collision>
  </link>
  <joint name="motor_1" type="continuous">
    <parent link="base_link"/>
    <child link="solid"/>
    <axis xyz="0.000796 0 1"/>
    <limit effort="10" velocity="10"/>
    <origin xyz="0.045 0 0.025" rpy="0 1.57 0"/>
  </joint>
  <link name="solid">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.01"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.01"/>
      </geometry>
    </collision>
  </link>
</robot>

